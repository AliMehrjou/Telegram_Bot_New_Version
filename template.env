# --- Bot Configuration ---
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
REQUIRED_CHANNEL_ID=-100123456789
CHANNEL_INVITE_LINK=https://t.me/aliandarianbot
BOT_USERNAME=@YourBotUsername
SUPPORT_USERNAME=@YourSupportHandle
ADMIN_USER_IDS=6722340162,1070403759

# --- Infrastructure & Networking ---
DOMAIN=example.com
ACME_EMAIL=your-email@example.com
# To generate DASHBOARD_AUTH: echo $(htpasswd -nB user) | sed -e s/\\$/\\$\\$/g
DASHBOARD_AUTH=user:$$2y$$05$$... (hashed password)

# --- Database Configuration (Internal Docker) ---
DB_HOST=mysql_db
DB_PORT=3306
DB_NAME=match_bot_db
DB_USER=match_bot_user
DB_PASSWORD=match_bot_password_secure_123
DB_ROOT_PASSWORD=root_secure_password_123
DATABASE_URL=mysql+aiomysql://match_bot_user:match_bot_password_secure_123@mysql_db:3306/match_bot_db

# --- Redis Configuration ---
REDIS_HOST=redis_cache
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass_123

# --- Web Server ---
PORT=8000
HOST=0.0.0.0
WEBHOOK_PATH=/api/v1/webhook
BASE_URL=https://example.com
